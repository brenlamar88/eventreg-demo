# V8 Event Platform — environment
#
# LOCAL DEV / DEMO: leave the Supabase vars unset. The app runs in "open mode"
# (org picker, no login) and the tests use the local Postgres cluster.

# Database (the app connects as the non-superuser app_user so RLS is enforced).
# On Supabase, point these at the pooler; DATABASE_URL_APP as a role subject to
# RLS, DATABASE_URL_ADMIN only for the open-mode platform screen.
DATABASE_URL_APP=postgres://app_user@127.0.0.1:55432/eventreg_test
DATABASE_URL_ADMIN=postgres://postgres@127.0.0.1:55432/eventreg_test

# Supabase Auth — set these (from your Supabase project settings) to turn on
# real login + membership-scoped tenancy. When both are present the app requires
# sign-in; when absent it stays in open demo mode.
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Stripe (Phase 2) — the operator's own Connect account; webhook signing secret.
# STRIPE_WEBHOOK_SECRET=whsec_...
