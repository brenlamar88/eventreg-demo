# V8 Event Platform — environment
#
# LOCAL DEV / DEMO: leave everything below unset. The app runs in "open mode"
# (org picker, no login) and the tests use the local Postgres cluster.

# Database (the app connects as the non-superuser app_user so RLS is enforced).
# On Supabase, point these at the pooler; DATABASE_URL_APP as a role subject to
# RLS (app_user), DATABASE_URL_ADMIN only for the open-mode platform screen.
# The app also reads POSTGRES_URL / POSTGRES_URL_NON_POOLING as fallbacks, which
# the one-click Supabase↔Vercel integration sets for you.
DATABASE_URL_APP=postgres://app_user@127.0.0.1:55432/eventreg_test
DATABASE_URL_ADMIN=postgres://postgres@127.0.0.1:55432/eventreg_test

# Supabase Auth — OPTIONAL. Presence of these keys alone does NOT turn on login
# (so the Supabase integration can set them without locking you out). Login is
# required only when NEXT_PUBLIC_AUTH_ENABLED is also "true".
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# NEXT_PUBLIC_AUTH_ENABLED=true

# Stripe (Phase 2) — the operator's own Connect account; webhook signing secret.
# STRIPE_WEBHOOK_SECRET=whsec_...
